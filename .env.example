NODE_ENV=production
PORT=3000

DATABASE_URL=postgresql://user:password@host:5432/lifo
REDIS_URL=redis://host:6379

JWT_ACCESS_SECRET=replace_with_long_random_value
JWT_REFRESH_SECRET=replace_with_long_random_value
ACCESS_TOKEN_TTL=15m
REFRESH_TOKEN_TTL_DAYS=7

COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_TENANT_NAME=LIFO
ENABLE_ADMIN_BOOTSTRAP=false
